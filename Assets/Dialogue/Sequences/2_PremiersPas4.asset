  m_Script: {fileID: 11500000, guid: 5cdbdbb5164c5b1479a3eca103fc935d, type: 3}
  m_Name: 2_PremiersPas4
  m_EditorClassIdentifier: 
  sequenceId: 002
  lines:
  - speakerName: AXI
    speakerPortrait: {fileID: 5978067422134562236, guid: 77184ec5a110d204882ecceb1e555656, type: 3}
    text: Ha, here's your first enemy !
    autoAdvanceDelay: 0
  - speakerName: AXI
    speakerPortrait: {fileID: 5978067422134562236, guid: 77184ec5a110d204882ecceb1e555656, type: 3}
    text: It's a Buffer. They usually attack in close combat.
    autoAdvanceDelay: 0
  - speakerName: You
    speakerPortrait: {fileID: 1751119502174200988, guid: 54ef6c48b4d05a3438e4973229e72209, type: 3}
    text: A buffer?
    autoAdvanceDelay: 0
  - speakerName: You
    speakerPortrait: {fileID: 1751119502174200988, guid: 54ef6c48b4d05a3438e4973229e72209, type: 3}
    text: (Why does it look like AXI?)
    autoAdvanceDelay: 0
  - speakerName: AXI
    speakerPortrait: {fileID: 5978067422134562236, guid: 77184ec5a110d204882ecceb1e555656, type: 3}
    text: Use the commands we went over together.
    autoAdvanceDelay: 0
  - speakerName: AXI
    speakerPortrait: {fileID: 5978067422134562236, guid: 77184ec5a110d204882ecceb1e555656, type: 3}
    text: "You can also use \u201Cspawn wall self\u201D to protect yourself."
    autoAdvanceDelay: 0
