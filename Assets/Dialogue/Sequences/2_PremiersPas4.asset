  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5cdbdbb5164c5b1479a3eca103fc935d, type: 3}
  m_Name: 2_PremiersPas4
  m_EditorClassIdentifier: 
  sequenceId: 002
  lines:
  - speakerName: AXI
    speakerPortrait: {fileID: 5978067422134562236, guid: 77184ec5a110d204882ecceb1e555656, type: 3}
    text: Ha, voici ton premier ennemi !
    autoAdvanceDelay: 0
  - speakerName: AXI
    speakerPortrait: {fileID: 5978067422134562236, guid: 77184ec5a110d204882ecceb1e555656, type: 3}
    text: C'est un Buffer. Ils attaquent generalement au corps a corps.
    autoAdvanceDelay: 0
  - speakerName: You
    speakerPortrait: {fileID: 1751119502174200988, guid: 54ef6c48b4d05a3438e4973229e72209, type: 3}
    text: Un Buffer ?
    autoAdvanceDelay: 0
  - speakerName: You
    speakerPortrait: {fileID: 1751119502174200988, guid: 54ef6c48b4d05a3438e4973229e72209, type: 3}
    text: (Pourquoi il ressemble a AXI ?)
    autoAdvanceDelay: 0
  - speakerName: AXI
    speakerPortrait: {fileID: 5978067422134562236, guid: 77184ec5a110d204882ecceb1e555656, type: 3}
    text: Sert toi des commandes que l'on a vu ensemble.
    autoAdvanceDelay: 0
  - speakerName: AXI
    speakerPortrait: {fileID: 5978067422134562236, guid: 77184ec5a110d204882ecceb1e555656, type: 3}
    text: Tu peux aussi utiliser "spawn wall self" pour de proteger.
    autoAdvanceDelay: 0
