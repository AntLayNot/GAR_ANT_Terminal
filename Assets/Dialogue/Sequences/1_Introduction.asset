--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5cdbdbb5164c5b1479a3eca103fc935d, type: 3}
  m_Name: 1_Introduction
  m_EditorClassIdentifier: 
  sequenceId: 001
  lines:
  - speakerName: You
    speakerPortrait: {fileID: 1751119502174200988, guid: 54ef6c48b4d05a3438e4973229e72209, type: 3}
    text: ... Where am I... Ugh, my head !
    autoAdvanceDelay: 0
  - speakerName: AXI
    speakerPortrait: {fileID: 5978067422134562236, guid: 77184ec5a110d204882ecceb1e555656, type: 3}
    text: Oh, you're awake. Are you okay ?
    autoAdvanceDelay: 0
  - speakerName: You
    speakerPortrait: {fileID: 1751119502174200988, guid: 54ef6c48b4d05a3438e4973229e72209, type: 3}
    text: I don't know. Where am I? And who are you ?
    autoAdvanceDelay: 0
  - speakerName: AXI
    speakerPortrait: {fileID: 1751119502174200988, guid: 54ef6c48b4d05a3438e4973229e72209, type: 3}
    text: "Wow, you're asking a lot of questions. First of all, you're on a plain,
      I think that's pretty obvious, isn't it ? Anyway, I'm \u201CAXI,\u201D a robot
      and your guide at your service!"
    autoAdvanceDelay: 0
  - speakerName: You
    speakerPortrait: {fileID: 1751119502174200988, guid: 54ef6c48b4d05a3438e4973229e72209, type: 3}
    text: Oh, okay, so you're going to help me, if I understand correctly, is that
      right ?
    autoAdvanceDelay: 0
  - speakerName: AXI
    speakerPortrait: {fileID: 5978067422134562236, guid: 77184ec5a110d204882ecceb1e555656, type: 3}
    text: "Right, I'll show you the basics. You must have noticed that you have a
      strange screen in your pocket, that's the terminal. It lets you control the
      world around you. Open it with \u201CE\u201D and start by typing this: \u201Cspawn
      projectile self\u201D."
    autoAdvanceDelay: 0
