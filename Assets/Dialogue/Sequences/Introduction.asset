MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5cdbdbb5164c5b1479a3eca103fc935d, type: 3}
  m_Name: Introduction
  m_EditorClassIdentifier: 
  sequenceId: 001
  lines:
  - speakerName: You
    speakerPortrait: {fileID: 21300000, guid: 5085baabfb59f784b93ff326abd0d16b, type: 3}
    text: "... Ou suis-je... Haarg, ma t\xEAte !"
    autoAdvanceDelay: 0
  - speakerName: AXI
    speakerPortrait: {fileID: -6117479970154661979, guid: 7d9880afa6cad4744b163051e4ee10f3, type: 3}
    text: "OH, tu es r\xE9veill\xE9, ca va ?"
    autoAdvanceDelay: 0
  - speakerName: You
    speakerPortrait: {fileID: 21300000, guid: 5085baabfb59f784b93ff326abd0d16b, type: 3}
    text: Je ne sais pas. Ou suis-je ? Et t'es qui toi ?
    autoAdvanceDelay: 0
  - speakerName: AXI
    speakerPortrait: {fileID: -6117479970154661979, guid: 7d9880afa6cad4744b163051e4ee10f3, type: 3}
    text: "Oula, tu poses beaucoup de questions. Pour commencer, tu es dans une for\xEAt
      je crois que \xE7a se voit assez bien non ? Ensuite moi je suis \"AXI\", robot
      et accompagnateur, \xE0 ton service !"
    autoAdvanceDelay: 0
  - speakerName: You
    speakerPortrait: {fileID: 21300000, guid: 5085baabfb59f784b93ff326abd0d16b, type: 3}
    text: "Oh, ok, donc tu vas m'aider si j'ai bien compris, c'est \xE7a ?"
    autoAdvanceDelay: 0
  - speakerName: AXI
    speakerPortrait: {fileID: -6117479970154661979, guid: 7d9880afa6cad4744b163051e4ee10f3, type: 3}
    text: "C'est \xE7a, je vais te montrer les bases, tu as du remarquer que tu avais
      un \xE9cran bizarre dans ta poche, c'est le terminal, il te permet de controller
      le monde qui t'entoure. Ouvre le avec \"E\" et commence par \xE9crire \xE7a
      : \" spawn projectile self \"."
    autoAdvanceDelay: 0
