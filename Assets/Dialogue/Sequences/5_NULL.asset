  lines:
  - speakerName: NULL
    speakerPortrait: {fileID: 320954253821206052, guid: a2e00406c4a4f5c44a2768eb8a4e4a9f, type: 3}
    text: You won't escape deletion.
    autoAdvanceDelay: 0
  - speakerName: You
    speakerPortrait: {fileID: 1751119502174200988, guid: 54ef6c48b4d05a3438e4973229e72209, type: 3}
    text: Who's there ?
    autoAdvanceDelay: 0
  - speakerName: NULL
    speakerPortrait: {fileID: 320954253821206052, guid: a2e00406c4a4f5c44a2768eb8a4e4a9f, type: 3}
    text: "I am ROOT / \xD8's right-hand man."
    autoAdvanceDelay: 0
  - speakerName: You
    speakerPortrait: {fileID: 1751119502174200988, guid: 54ef6c48b4d05a3438e4973229e72209, type: 3}
    text: "ROOT / \xD8 ? Who is ROOT / \xD8 ?"
    autoAdvanceDelay: 0
  - speakerName: NULL
    speakerPortrait: {fileID: 320954253821206052, guid: a2e00406c4a4f5c44a2768eb8a4e4a9f, type: 3}
    text: The virus that will take control of your computer.
    autoAdvanceDelay: 0
  - speakerName: You
    speakerPortrait: {fileID: 1751119502174200988, guid: 54ef6c48b4d05a3438e4973229e72209, type: 3}
    text: We'll see.
    autoAdvanceDelay: 0
