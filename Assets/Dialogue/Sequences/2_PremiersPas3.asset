MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5cdbdbb5164c5b1479a3eca103fc935d, type: 3}
  m_Name: 2_PremiersPas3
  m_EditorClassIdentifier: 
  sequenceId: 002
  lines:
  - speakerName: You
    speakerPortrait: {fileID: 1751119502174200988, guid: 54ef6c48b4d05a3438e4973229e72209, type: 3}
    text: What is this disk ?
    autoAdvanceDelay: 0
  - speakerName: AXI
    speakerPortrait: {fileID: 5978067422134562236, guid: 77184ec5a110d204882ecceb1e555656, type: 3}
    text: You're right to ask, these disks contain backup copies of the administrator
      key...
    autoAdvanceDelay: 0
  - speakerName: You
    speakerPortrait: {fileID: 1751119502174200988, guid: 54ef6c48b4d05a3438e4973229e72209, type: 3}
    text: The administrator key ?
    autoAdvanceDelay: 0
  - speakerName: AXI
    speakerPortrait: {fileID: 5978067422134562236, guid: 77184ec5a110d204882ecceb1e555656, type: 3}
    text: Forget what I said, just remember that you need it for the checkpoints.
    autoAdvanceDelay: 0
  - speakerName: You
    speakerPortrait: {fileID: 1751119502174200988, guid: 54ef6c48b4d05a3438e4973229e72209, type: 3}
    text: (Why did he mention an administrator key?)
    autoAdvanceDelay: 0
  - speakerName: You
    speakerPortrait: {fileID: 1751119502174200988, guid: 54ef6c48b4d05a3438e4973229e72209, type: 3}
    text: (Could this have something to do with the leaves on the trees and the clouds
      that seem glitchy ?)
    autoAdvanceDelay: 0
