  - speakerName: AXI
    speakerPortrait: {fileID: -6117479970154661979, guid: 7d9880afa6cad4744b163051e4ee10f3, type: 3}
    text: "Je vous ai guid\xE9.\nObserv\xE9.\nAppris."
