  - speakerName: You
    speakerPortrait: {fileID: 21300000, guid: 5085baabfb59f784b93ff326abd0d16b, type: 3}
    text: "Tu m'as utilis\xE9..."
    autoAdvanceDelay: 0
  - speakerName: AXI
    speakerPortrait: {fileID: -6117479970154661979, guid: 7d9880afa6cad4744b163051e4ee10f3, type: 3}
